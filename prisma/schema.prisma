// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       Int      @id @default(autoincrement())
  username String   @unique
  name     String
  email    String   @unique
  password String
  role     UserRole @default(USER)

  // Password Reset
  resetToken       String?   @unique
  resetTokenExpiry DateTime?

  // Profile Information
  phone_number        String?
  company_name        String?
  company_size        String?
  company_description String?
  founded_year        Int?
  website             String?
  profile_photo_url   String?
  job_title           String?
  industry            String?
  bio                 String?
  timezone            String?

  // Social Links
  linkedin_url          String?
  website_url           String?
  secondary_social_url  String?
  secondary_social_type String?

  // Preferences & Settings
  preferred_working_hours       Json     @default("{}")
  communication_preference      String?
  primary_work_focus            String?
  profile_completion_percentage Int      @default(20)
  last_profile_update           DateTime @default(now())

  // Work Duration Preferences (AI Recommendation System)
  deep_work_start_time       String @default("09:00")
  deep_work_end_time         String @default("12:00")
  creative_work_start_time   String @default("12:00")
  creative_work_end_time     String @default("15:00")
  reflective_work_start_time String @default("15:00")
  reflective_work_end_time   String @default("18:00")
  executive_work_start_time  String @default("18:00")
  executive_work_end_time    String @default("21:00")

  // Credits System
  credits               Int      @default(100)
  credit_refresh_period String   @default("monthly")
  credit_refresh_amount Int      @default(100)
  last_credit_refresh   DateTime @default(now())

  // Profile Visibility
  profileVisibility ProfileVisibility @default(PRIVATE)

  // Active Status Tracking (based on focus sessions)
  isOnline        Boolean   @default(false) @map("is_online")
  statusUpdatedAt DateTime? @map("status_updated_at")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  projects                 Project[]
  objectives               Objective[]
  okrs                     Okr[]
  tasks                    Task[]
  userSettings             UserSettings?
  focusSessions            FocusSession[]
  cognitiveLoadMeter       CognitiveLoadMeter?
  userProductivityPatterns UserProductivityPatterns?
  userFocusPreferences     UserFocusPreferences?

  // Workspace/Team relations
  ownedWorkspaces      Workspace[]
  teamMemberships      TeamMembership[]
  workspaceMemberships WorkspaceMembership[]

  // Subscription relation
  subscription Subscription?

  // Referral relations
  referralStatus    UserReferralStatus?
  referralsMade     Referral[]          @relation("Referrer")
  referralsReceived Referral[]          @relation("ReferredUser")

  // Focus Room relations
  createdFocusRooms            FocusRoom[]            @relation("FocusRoomCreator")
  focusRoomParticipations      FocusRoomParticipant[] @relation("FocusRoomParticipant")
  focusRoomInvitationsSent     FocusRoomInvitation[]  @relation("FocusRoomInviter")
  focusRoomInvitationsReceived FocusRoomInvitation[]  @relation("FocusRoomInvitee")
  focusRoomTemplates           FocusRoomTemplate[]    @relation("FocusRoomTemplateCreator")

  @@index([isOnline])
  @@index([statusUpdatedAt])
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  status      String?
  color       String    @default("#4A6CF7")
  icon        String?
  startDate   DateTime  @default(now())
  endDate     DateTime?
  createdAt   DateTime  @default(now())
  userId      Int
  is_private  Boolean   @default(false)
  visibility  String    @default("private")
  workspaceId Int?
  teamId      Int?

  // Relations
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace  Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team       Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  plans      Plan[]
  tasks      Task[]
  objectives Objective[]
}

model Objective {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  status      String    @default("active")
  color       String    @default("#4A6CF7")
  start_date  DateTime  @default(now())
  end_date    DateTime?
  created_at  DateTime  @default(now())
  position    Int       @default(0)
  workspaceId Int?
  teamId      Int?

  // Relations
  userId    Int
  projectId Int?
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team      Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  plans     Plan[]
  okrs      Okr[]
  tasks     Task[]
}

model Plan {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  status      String   @default("active")
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Relations
  projectId   Int
  objectiveId Int
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  objective   Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  okrs        Okr[]
  tasks       Task[]

  @@unique([projectId, objectiveId])
}

model Okr {
  id              Int       @id @default(autoincrement())
  title           String
  description     String?
  status          String    @default("notStarted")
  targetValue     Float
  currentValue    Float     @default(0)
  startDate       DateTime  @default(now())
  endDate         DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  userId          Int
  objectiveId     Int? // Made optional
  planId          Int? // Added optional Plan reference
  position        Int       @default(0)
  confidenceScore Int       @default(3)
  keyResults      Json      @default("[]")
  progressHistory Json      @default("[]")
  workspaceId     Int?
  teamId          Int?

  // Relations
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  objective Objective? @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  plan      Plan?      @relation(fields: [planId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team      Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  category    String
  duration    Int
  priority    String
  position    Int
  createdAt   DateTime  @default(now())
  completed   Boolean   @default(false)
  dueDate     DateTime?

  // Eisenhower Matrix
  importance Boolean @default(false)
  urgency    Boolean @default(false)

  // Signal Layer (User-controlled toggles from frontend UI)
  isHighLeverage     Boolean @default(false) // HLA toggle - High-Leverage Activity
  advancesKeyResults Boolean @default(false) // AKR toggle - Advances Key Results

  // Relations
  userId      Int
  projectId   Int?
  objectiveId Int?
  okrId       Int?
  planId      Int? // Added optional Plan reference
  workspaceId Int?
  teamId      Int?

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  objective Objective? @relation(fields: [objectiveId], references: [id], onDelete: Cascade)
  okr       Okr?       @relation(fields: [okrId], references: [id], onDelete: Cascade)
  plan      Plan?      @relation(fields: [planId], references: [id], onDelete: Cascade)
  workspace Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  team      Team?      @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // AI Recommendation relation
  aiRecommendation AIRecommendation?

  @@index([userId, completed])
}

model AIRecommendation {
  id              Int     @id @default(autoincrement())
  taskId          Int     @unique
  category        String // DEEP_WORK, CREATIVE_WORK, REFLECTIVE_WORK, EXECUTIVE_WORK
  recommendedTime String // Time in HH:MM format
  confidence      Float // 0.0 to 1.0
  reasoning       String? // Optional reasoning text

  // Enhanced Signal Layer fields
  signalType          String? // Core-Signal | High-Signal | Strategic-Signal | Neutral | Noise
  recommendedDuration Int? // Recommended duration in minutes (25-90)
  breakRecommendation String? // Break advice (e.g., "Take a 5-10 min break")
  loadWarning         String? // Load warning message (e.g., "Multiple high-load sessions detected")
  importanceFlag      Boolean? // For conflict detection with Signal Layer
  urgencyFlag         Boolean? // For conflict detection with Signal Layer
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id        Int      @id @default(autoincrement())
  language  String   @default("english")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FocusSession {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  sessionType    String    @map("session_type")
  status         String    @default("active")
  intention      Json      @default("{}")
  startedAt      DateTime  @default(now()) @map("started_at")
  endedAt        DateTime? @map("ended_at")
  pausedAt       DateTime? @map("paused_at")
  resumedAt      DateTime? @map("resumed_at")
  duration       Int       @default(0)
  completed      Boolean   @default(false)
  notes          String?
  tasksCompleted Int       @default(0) @map("tasks_completed")
  createdAt      DateTime  @default(now()) @map("created_at")

  // AI Analytics
  aiScore                Int?    @map("ai_score")
  distractions           Int     @default(0)
  environment            String?
  mood                   String?
  energyLevel            String? @map("energy_level")
  cognitiveFlowScore     Int?    @map("cognitive_flow_score")
  contextSwitchCount     Int     @default(0) @map("context_switch_count")
  flowState              String? @map("flow_state")
  taskGroupEffectiveness Json    @default("{}") @map("task_group_effectiveness")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionType, status, startedAt], name: "focus_sessions_user_type_status_started_at_idx")
  @@map("focus_sessions")
}

model CognitiveLoadMeter {
  id                              Int      @id @default(autoincrement())
  userId                          Int      @map("user_id")
  currentWorkloadScore            Int      @default(50) @map("current_workload_score")
  cognitiveCapacity               Int      @default(100) @map("cognitive_capacity")
  sustainableCapacity             Int      @default(75) @map("sustainable_capacity")
  burnoutRiskScore                Int      @default(0) @map("burnout_risk_score")
  burnoutRiskLevel                String   @default("NONE") @map("burnout_risk_level")
  recoveryRate                    Int      @default(5) @map("recovery_rate")
  workloadHistory                 Json     @default("[]") @map("workload_history")
  capacityUtilization             Json     @default("[]") @map("capacity_utilization")
  recommendedTaskLimit            Int?     @map("recommended_task_limit")
  recommendedFocusSessionDuration Int?     @map("recommended_focus_session_duration")
  recommendedBreakFrequency       Int?     @map("recommended_break_frequency")
  currentStatus                   String   @default("OPTIMAL") @map("current_status")
  createdAt                       DateTime @default(now()) @map("created_at")
  updatedAt                       DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("cognitive_load_meters")
}

model UserProductivityPatterns {
  id                          Int      @id @default(autoincrement())
  userId                      Int      @map("user_id")
  hourlyPatterns              Json     @default("{}") @map("hourly_patterns")
  dayOfWeekPatterns           Json     @default("{}") @map("day_of_week_patterns")
  taskSwitchingMetrics        Json     @default("{}") @map("task_switching_metrics")
  taskCompletionRate          Float    @default(0.0) @map("task_completion_rate")
  averageFocusSessionDuration Int      @default(25) @map("average_focus_session_duration")
  peakProductivityHours       Json     @default("[]") @map("peak_productivity_hours")
  energyPattern               String?  @map("energy_pattern")
  contextSwitchingProfile     String?  @map("context_switching_profile")
  recoveryPattern             String?  @map("recovery_pattern")
  createdAt                   DateTime @default(now()) @map("created_at")
  updatedAt                   DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("user_productivity_patterns")
}

model UserFocusPreferences {
  id                       Int      @id @default(autoincrement())
  userId                   Int      @map("user_id")
  workingHours             Json     @default("{}") @map("working_hours")
  cognitiveLoadPreferences Json     @default("{}") @map("cognitive_load_preferences")
  preferredFocusDuration   Int      @default(25) @map("preferred_focus_duration")
  preferredBreakDuration   Int      @default(5) @map("preferred_break_duration")
  maxConsecutiveSessions   Int      @default(4) @map("max_consecutive_sessions")
  breakFrequency           Int      @default(5) @map("break_frequency")
  deepWorkPreferences      Json     @default("{}") @map("deep_work_preferences")
  environmentPreferences   Json     @default("{}") @map("environment_preferences")
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("user_focus_preferences")
}

enum UserRole {
  USER
  ADMIN
}

enum TeamRole {
  ADMIN
  MEMBER
  TEAM_MANAGER
}

enum TeamMemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  UNDER_REVIEW
}

enum WorkspaceRole {
  WORKSPACE_MANAGER
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ownerId     Int
  owner       User                  @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  teams       Team[]
  projects    Project[]
  objectives  Objective[]
  okrs        Okr[]
  tasks       Task[]
  memberships WorkspaceMembership[]
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workspaceId Int
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships TeamMembership[]
  projects    Project[]
  objectives  Objective[]
  okrs        Okr[]
  tasks       Task[]
}

model TeamMembership {
  id        Int              @id @default(autoincrement())
  role      TeamRole         @default(MEMBER)
  status    TeamMemberStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  // Relations
  userId Int
  teamId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model WorkspaceMembership {
  id        Int           @id @default(autoincrement())
  role      WorkspaceRole
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  // Relations
  userId      Int
  workspaceId Int
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

// ============================================
// Subscription & Payment Models
// ============================================

model PaymentProvider {
  id        Int      @id @default(autoincrement())
  name      String   @unique // "stripe", "paypal", etc.
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]
  payments      Payment[]
}

model SubscriptionPlan {
  id              Int      @id @default(autoincrement())
  name            String   @unique // "trial", "monthly", "yearly", "free"
  displayName     String // "Free Trial", "Monthly Plan", "Yearly Plan"
  description     String?
  price           Float // Price in USD (0 for trial)
  currency        String   @default("USD")
  billingInterval String // "trial", "monthly", "yearly", "free"
  trialDays       Int? // 3 for trial plan
  maxTasks        Int? // 50 for trial, 1000 for monthly, 10000 for yearly
  maxProjects     Int? // Limit for projects per billing period
  maxObjectives   Int? // Limit for objectives per billing period
  maxKeyResults   Int? // Limit for key results per billing period
  maxWorkspaces   Int? // Limit for workspaces
  maxTeams        Int? // Limit for teams per workspace
  features        Json     @default("{}") // Feature flags as JSON
  isActive        Boolean  @default(true)
  stripePriceId   String? // Stripe Price ID (set manually in Stripe Dashboard)
  stripeProductId String? // Stripe Product ID (set manually in Stripe Dashboard)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions Subscription[]
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  INCOMPLETE
  GRACE_PERIOD
}

model Subscription {
  id                     Int                @id @default(autoincrement())
  userId                 Int                @unique
  subscriptionPlanId     Int
  paymentProviderId      Int? // Nullable for free plans that don't use payment providers
  status                 SubscriptionStatus @default(TRIAL)
  stripeSubscriptionId   String?            @unique // Stripe Subscription ID
  stripeCustomerId       String? // Stripe Customer ID
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  trialStart             DateTime? // When trial started
  trialEnd               DateTime? // When trial ends (3 days from trialStart)
  gracePeriodEnd         DateTime? // When grace period ends (3 days after subscription expires)
  cancelAtPeriodEnd      Boolean            @default(false)
  canceledAt             DateTime?
  tasksCreatedThisPeriod Int                @default(0) // Track tasks created in current billing period
  projectsCreatedThisPeriod Int             @default(0) // Track projects created in current billing period
  objectivesCreatedThisPeriod Int           @default(0) // Track objectives created in current billing period
  keyResultsCreatedThisPeriod Int           @default(0) // Track key results created in current billing period
  workspacesCreatedThisPeriod Int           @default(0) // Track workspaces created in current billing period
  teamsCreatedThisPeriod Int                @default(0) // Track teams created in current billing period
  lastTaskCountReset     DateTime? // When task count was last reset
  lastCountReset          DateTime? // When all counts were last reset (for monthly renewal)
  paymentRetryCount      Int                @default(0) // Track payment retry attempts (max 3)
  lastPaymentRetryAt     DateTime? // Timestamp of last payment retry
  paymentFailureReason   String? // Reason for payment failure
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])
  paymentProvider  PaymentProvider? @relation(fields: [paymentProviderId], references: [id])
  payments         Payment[]

  @@index([userId, status])
  @@index([status, currentPeriodEnd])
}

model Payment {
  id                    Int      @id @default(autoincrement())
  subscriptionId        Int
  paymentProviderId     Int
  amount                Float // Amount charged
  currency              String   @default("USD")
  paymentType           String // "subscription", "one_time", "refund", "partial_refund"
  paymentMethod         String? // "card", "bank_transfer", etc.
  status                String // "pending", "succeeded", "failed", "refunded", "partially_refunded"
  stripePaymentIntentId String? // Stripe Payment Intent ID or Charge ID
  stripeInvoiceId       String? // Stripe Invoice ID
  receiptUrl            String? // Link to receipt
  failureReason         String? // If payment failed
  metadata              Json     @default("{}") // Additional metadata
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  subscription    Subscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  paymentProvider PaymentProvider @relation(fields: [paymentProviderId], references: [id])

  @@index([subscriptionId, status])
  @@index([stripePaymentIntentId])
}

// ============================================
// Referral System Models
// ============================================

enum EarlyAccessStatus {
  NONE
  ORIGIN
  VANGUARD
}

enum ReferralStatus {
  INVITED
  REGISTERED
  COMPLETED
}

enum ProfileVisibility {
  PRIVATE
  PUBLIC
  FRIENDS_ONLY
}

model ReferralProgram {
  id                Int      @id @default(autoincrement())
  name              String   @unique // "Origin 1000" or "Vanguard 300"
  description       String?
  totalSeats        Int // 1000 for Origin, 300 for Vanguard
  requiredReferrals Int      @default(0) // 0 for Origin, 3 for Vanguard
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("referral_programs")
}

model UserReferralStatus {
  id                Int               @id @default(autoincrement())
  userId            Int               @unique
  earlyAccessStatus EarlyAccessStatus @default(NONE)
  referralCode      String            @unique // Unique 10-character code
  rewardsUnlocked   Boolean           @default(false)
  originId          String?           @unique // Format: ORG-001
  vanguardId        String?           @unique // Format: VNG-001
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([referralCode])
  @@index([earlyAccessStatus])
  @@map("user_referral_status")
}

model Referral {
  id           Int            @id @default(autoincrement())
  referrerId   Int // User who made the referral
  referredId   Int            @unique // User who was referred (unique)
  referralCode String // Referral code used
  status       ReferralStatus @default(INVITED)
  completedAt  DateTime? // When onboarding completed
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  referrer User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferredUser", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId, status])
  @@index([referralCode])
  @@index([status])
  @@map("referrals")
}

model ReferralClick {
  id            Int      @id @default(autoincrement())
  referralCode  String // Referral code clicked
  visitorIpHash String // Hashed IP for privacy (SHA-256)
  userAgent     String?
  referer       String?
  converted     Boolean  @default(false) // Whether click led to signup
  createdAt     DateTime @default(now())

  @@index([referralCode])
  @@index([createdAt])
  @@map("referral_clicks")
}

// ============================================
// Focus Rooms Models
// ============================================

model FocusRoom {
  id                 Int                 @id @default(autoincrement())
  name               String              @db.VarChar(50)
  description        String?             @db.VarChar(500)
  creatorId          Int                 @map("creator_id")
  status             String              @default("active") @db.VarChar(20) // draft, active, scheduled, completed, archived
  visibility         FocusRoomVisibility @default(PUBLIC)
  focusDuration      Int                 @default(25) @map("focus_duration") // in minutes
  breakDuration      Int                 @default(5) @map("break_duration") // in minutes
  allowObservers     Boolean             @default(true) @map("allow_observers")
  passwordHash       String?             @map("password_hash") @db.VarChar(100)
  requiresPassword   Boolean             @default(false) @map("requires_password")
  settings           Json?               @default("{}")
  scheduledStartTime DateTime?           @map("scheduled_start_time")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  creator      User                   @relation("FocusRoomCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  sessions     FocusRoomSession[]
  participants FocusRoomParticipant[]
  invitations  FocusRoomInvitation[]

  @@index([status, visibility])
  @@index([creatorId])
  @@map("focus_rooms")
}

model FocusRoomSession {
  id                Int                @id @default(autoincrement())
  roomId            Int                @map("room_id")
  startedAt         DateTime           @map("started_at")
  endedAt           DateTime?          @map("ended_at")
  pausedAt          DateTime?          @map("paused_at")
  resumedAt         DateTime?          @map("resumed_at")
  scheduledDuration Int                @map("scheduled_duration") // in seconds
  actualDuration    Int?               @map("actual_duration") // in seconds
  status            FocusSessionStatus @default(ACTIVE)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")

  room FocusRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId, status])
  @@index([startedAt])
  @@map("focus_room_sessions")
}

model FocusRoomParticipant {
  id              Int                    @id @default(autoincrement())
  roomId          Int                    @map("room_id")
  userId          Int                    @map("user_id")
  role            FocusParticipantRole   @default(PARTICIPANT)
  status          FocusParticipantStatus @default(JOINED)
  joinedAt        DateTime               @default(now()) @map("joined_at")
  leftAt          DateTime?              @map("left_at")
  intention       String?                @db.Text
  completion      String?                @db.Text
  shareCompletion Boolean                @default(false) @map("share_completion")
  createdAt       DateTime               @default(now()) @map("created_at")
  updatedAt       DateTime               @updatedAt @map("updated_at")

  room FocusRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User      @relation("FocusRoomParticipant", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId], name: "room_user_idx")
  @@index([roomId, status])
  @@map("focus_room_participants")
}

model FocusRoomInvitation {
  id           Int              @id @default(autoincrement())
  roomId       Int              @map("room_id")
  inviterId    Int              @map("inviter_id")
  inviteeId    Int?             @map("invitee_id")
  inviteeEmail String           @map("invitee_email") @db.VarChar(255)
  token        String           @unique @db.VarChar(255)
  status       InvitationStatus @default(PENDING)
  expiresAt    DateTime         @map("expires_at")
  respondedAt  DateTime?        @map("responded_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  room    FocusRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inviter User      @relation("FocusRoomInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee User?     @relation("FocusRoomInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([roomId, status])
  @@index([inviteeEmail, status])
  @@map("focus_room_invitations")
}

model FocusRoomTemplate {
  id             Int                  @id @default(autoincrement())
  name           String               @db.VarChar(100)
  description    String?              @db.Text
  creatorId      Int                  @map("creator_id")
  isSystem       Boolean              @default(false) @map("is_system")
  category       RoomTemplateCategory @default(CUSTOM)
  focusDuration  Int                  @default(25) @map("focus_duration")
  breakDuration  Int                  @default(5) @map("break_duration")
  allowObservers Boolean              @default(true) @map("allow_observers")
  visibility     FocusRoomVisibility  @default(PUBLIC)
  settings       Json?                @default("{}")
  usageCount     Int                  @default(0) @map("usage_count")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  creator User @relation("FocusRoomTemplateCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([category, isSystem])
  @@map("focus_room_templates")
}

enum FocusRoomVisibility {
  PUBLIC
  PRIVATE
}

enum FocusSessionStatus {
  PENDING
  ACTIVE
  PAUSED
  COMPLETED
}

enum FocusParticipantRole {
  CREATOR
  PARTICIPANT
}

enum FocusParticipantStatus {
  JOINED
  FOCUSING
  BREAK
  IDLE
  LEFT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum RoomTemplateCategory {
  DEEP_WORK
  CREATIVE
  PLANNING
  LEARNING
  CUSTOM
}
